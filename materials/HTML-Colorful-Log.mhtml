powershell -Command "$OutputEncoding =3D [System.Text.Encoding]::UTF8; &amp=
; '%PYTHON_EXE%' -u 'wqbagent_output_test.py' *&gt;&amp;1 | Tee-Object -Fil=
ePath '%TRANSCRIPT%'"

