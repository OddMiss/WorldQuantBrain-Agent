78185806-170">@echo off
setlocal enabledelayedexpansion

:: --- NEW: Force Windows terminal to use UTF-8 ---
chcp 65001 &gt;nul

:: 1. Get robust date and time formatting using PowerShell
for /f "usebackq tokens=3D*" %%i in (`powershell -Command "Get-Date -Format=
 'yyyyMM'"`) do set "DIR_DATE=3D%%i"
for /f "usebackq tokens=3D*" %%i in (`powershell -Command "Get-Date -Format=
 'yyyyMMdd-HHmmss'"`) do set "FILE_DATE=3D%%i"

:: 2. Define Directories=20
:: PARENT_DIR is "WorldQuantBrain-Agent"
set "PARENT_DIR=3D%~dp0.."
:: VENV_PATH is "root\wqbagentportablevenv"
set "VENV_PATH=3D%~dp0..\..\wqbagentportablevenv"
set "LOG_DIR=3D%PARENT_DIR%\logs\%DIR_DATE%"

:: 3. Create the log directory if it does not exist
if not exist "%LOG_DIR%" (
    mkdir "%LOG_DIR%"
    echo [INFO] Created new log directory: %LOG_DIR%
)

set "OUTPUT_FILE=3D%LOG_DIR%\wqb_agent-%FILE_DATE%.html"
set "TRANSCRIPT=3D%LOG_DIR%\wqb_agent-%FILE_DATE%.transcript.txt"

echo =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D
echo =F0=9F=9A=80 Starting WorldQuant Brain Agent Pipeline...
echo =F0=9F=93=82 Output will be saved to:=20
echo    %OUTPUT_FILE%
echo =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D

:: 4. Move into the parent directory (WorldQuantBrain-Agent)
cd /d "%PARENT_DIR%"

:: 5. ACTIVATE YOUR VIRTUAL ENVIRONMENT (Using Relative Path)
echo [INFO] Activating virtual environment...
call "%VENV_PATH%\Scripts\activate.bat"

:: Run Python, pipe to PowerShell to "Tee" (split) the stream.
echo [INFO] Running Agent Pipeline...

python -u "%PARENT_DIR%\wqbagent_output_test.py"

:: Deactivate the environment when done
call deactivate

echo.
echo =E2=9C=85 Process Complete! You can view the log in your browser.
pause
