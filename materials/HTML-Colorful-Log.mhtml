>@echo off
setlocal enabledelayedexpansion

:: --- Force Windows terminal to use UTF-8 ---
chcp 65001 &gt;nul

:: 1. Get robust date and time formatting using PowerShell
for /f "usebackq tokens=3D*" %%i in (`powershell -Command "Get-Date -Format=
 'yyyyMM'"`) do set "DIR_DATE=3D%%i"
for /f "usebackq tokens=3D*" %%i in (`powershell -Command "Get-Date -Format=
 'yyyyMMdd-HHmmss'"`) do set "FILE_DATE=3D%%i"

:: 2. Define Relative Paths
:: PARENT_DIR is "WorldQuantBrain-Agent"
set "PARENT_DIR=3D%~dp0.."
:: PYTHON_EXE is in the portable folder (root\wqbagentportablevenv)
set "PYTHON_EXE=3D%~dp0..\..\wqbagentportablevenv\python.exe"

set "LOG_DIR=3D%PARENT_DIR%\logs\%DIR_DATE%"

:: 3. Create the log directory if it does not exist
if not exist "%LOG_DIR%" (
    mkdir "%LOG_DIR%"
    echo [INFO] Created new log directory: %LOG_DIR%
)

set "OUTPUT_FILE=3D%LOG_DIR%\wqb_agent-%FILE_DATE%.html"
set "TRANSCRIPT=3D%LOG_DIR%\wqb_agent-%FILE_DATE%.transcript.txt"

echo =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D
echo =F0=9F=9A=80 Starting WorldQuant Brain Agent Pipeline...
echo =F0=9F=93=82 Logs will be saved to:=20
echo    %TRANSCRIPT%
echo =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D

:: 4. Move into the working directory (WorldQuantBrain-Agent)
cd /d "%PARENT_DIR%"

:: 5. RUN PORTABLE PYTHON AND LOG OUTPUT
echo [INFO] Running Agent Pipeline...

:: We use PowerShell's Tee-Object to show output in terminal AND save to fi=
le.
:: *&gt;&amp;1 redirects all streams (Success, Error, Warning) so they all =
get logged.
powershell -Command "&amp; '%PYTHON_EXE%' -u 'wqbagent_output_test.py' *&gt=
;&amp;1 | Tee-Object -FilePath '%TRANSCRIPT%'"

:: 6. Create the HTML version
:: If you have ansi2html installed in your portable python, you can use it =
here.
:: Otherwise, this line creates a simple text-based HTML wrapper for the lo=
g.
(
    echo ^&lt;pre style=3D"background-color: #1e1e1e; color: #ffffff; paddi=
ng: 20px; font-family: monospace;"^&gt;
    type "%TRANSCRIPT%"
    echo ^&lt;/pre^&gt;
) &gt; "%OUTPUT_FILE%"

echo.
echo =E2=9C=85 Process Complete!=20
echo =F0=9F=93=84 Transcript: %TRANSCRIPT%
echo =F0=9F=8C=90 HTML Log:   %OUTPUT_FILE%
pause
</code></pre><!----></div></div></div><!----><!----><!----></code-block><!-=
