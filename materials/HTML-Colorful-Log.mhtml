err=3Dsubprocess.STDOUT, encoding=3D'utf-8', errors=3D'replace') &gt;&gt; _=
_tee_temp.py
echo     for line in p.stdout: &gt;&gt; __tee_temp.py
echo         sys.stdout.write(line) &gt;&gt; __tee_temp.py
echo         sys.stdout.flush() &gt;&gt; __tee_temp.py
echo         f.write(line) &gt;&gt; __tee_temp.py
echo         f.flush() &gt;&gt; __tee_temp.py
