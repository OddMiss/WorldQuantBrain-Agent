:: 4. THE FIX: Bypass PowerShell entirely to preserve color
:: We generate a temporary python script to safely pipe output without dest=
roying colors.
echo import sys, subprocess &gt; __tee_temp.py
echo with open(r'%TRANSCRIPT%', 'w', encoding=3D'utf-8') as f: &gt;&gt; __t=
ee_temp.py
