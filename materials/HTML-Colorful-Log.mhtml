=3D=3D=3D=3D=3D=3D=3D=3D
echo =F0=9F=9A=80 Starting WorldQuant Brain Agent Pipeline...
echo =F0=9F=93=82 Logs will be saved to:=20
echo    %TRANSCRIPT%
echo =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D

cd /d "%PARENT_DIR%"

:: 4. RUN WITH POWERSHELL UTF-8 PIPING
echo [INFO] Running Agent Pipeline...

powershell -Command "$OutputEncoding =3D [System.Text.Encoding]::UTF8; &amp=
; '%PYTHON_EXE%' -u 'wqbagent_output_test.py' *&gt;&amp;1 | Tee-Object -Fil=
ePath '%TRANSCRIPT%'"

:: 5. Create the HTML version (simple wrapper)
(
    echo ^&lt;pre style=3D"background-color: #1e1e1e; color: #ffffff; paddi=
ng: 20px; font-family: monospace;"^&gt;
    type "%TRANSCRIPT%"
    echo ^&lt;/pre^&gt;
) &gt; "%OUTPUT_FILE%"

echo.
echo =E2=9C=85 Process Complete!=20
pause
